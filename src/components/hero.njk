<section class="hero">
  <video class="hero__bg-video" autoplay="autoplay" muted="muted" playsinline="playsinline" loop="loop" preload="auto" poster="/assets/video/hero-video-poster.webp">
    <source src="/assets/video/hero-video.webm" type="video/webm">
    <source src="/assets/video/hero-video.mp4" type="video/mp4">
  </video>
  <div class="hero__container container">
    <div class="hero__top">
      <a href="/" class="hero__logo" aria-label="Re:Location IT Summit">
        {{ svgIcon("logo.svg") | safe }}
      </a>
    </div>
    <div class="hero__content">
      <div class="hero__info">
        <div class="event-info">8-10 октября 2026</div>
        <div class="event-info">
          <span class="event-info__icon">
            {{ svgIcon("barcelona-star.svg") | safe }}
          </span>
          Барселона
        </div>
      </div>
      <h1 class="hero__title">
        Главное событие для русскоязычного IT в эмиграции
      </h1>
      <p class="hero__subtitle">
        Тут фаундеры, айтишники и айтишницы находят идеи, проекты и друзей
      </p>
    </div>
    <div class="hero__buttons">
      <a href="#tickets" onclick="fbq('track', 'InitiateCheckout');" class="btn">Билеты и цены</a>
      <a href="#subscription" class="btn btn_outline">Подписаться</a>
    </div>
  </div>
</section>